# Database — SQLite for local dev; PostgreSQL for the LAN server, e.g.
# DATABASE_URL=postgresql+psycopg2://qa:qa@192.168.1.10:5432/qa_tasks
DATABASE_URL=sqlite:///./qa_tasks.db

# Auth — REQUIRED: set a long random string in real deployments
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# Optional SMTP notifications
EMAIL_ENABLED=false
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=qa-tasks@localhost

# AI agent — needs a local OpenAI-compatible LLM (Ollama / Gauss / OpenVINO)
AGENT_ENABLED=false
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1
LLM_API_KEY=ollama

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
